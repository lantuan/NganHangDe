        # CHỦ ĐỘNG BỌC 1 CẶP DẤU DOLLAR DUY NHẤT Ở ĐỀ BÀI VÀ CÁC PHƯƠNG ÁN CHỌN KHÔNG BỊ LỖI TEXT
        debai = f"""Tìm mệnh đề phủ định của mệnh đề: ``${P}$''."""

        dapso = f"""${p}$"""
        dsnhieu = [f"""${p1}$""", f"""${p2}$""", f"""${p3}$"""]

        giai = f"""Phủ định của mệnh đề chứa lượng từ được xác định bằng cách đảo ngược ký hiệu lượng từ và phủ định tính chất của vị từ:\\\\
        - Lượng từ $\\forall$ chuyển thành $\\exists$ (và ngược lại).\\\\
        - Các dấu so sánh, tính chất thuộc tập hợp biến đổi thành phủ định tương ứng ($>$ thành $\\le$, $=$ thành $\\ne$, $\\in$ thành $\\not\\in$,...).\\\\
        Do đó, phủ định của mệnh đề ``${P}$'' là ``${p}$''."""

        cauTN += MC_SA_answer_text(debai, dapso, dsnhieu, giai, 0, 0, dang)

    return cauTN


def K10_C1_B2_TapConSo_MC_NB(socau, dang):
    x = Symbol('x')
    y = Symbol('y')

    gt = []
    dem = len(gt)
    while dem < socau:
        A_list = []
        k = np.random.randint(3, 5)  # Tập hợp gồm 3 hoặc 4 phần tử
        for i in range(0, k):
            a_val = np.random.randint(-9, 10)
            while a_val in A_list:
                a_val = np.random.randint(-9, 10)
            A_list.append(a_val)

        # Sắp xếp lại danh sách phần tử tăng dần để hiển thị tập hợp đẹp và chuẩn toán học
        A_list.sort()

        v = [A_list]
        if v not in gt:
            gt.append(v)
            dem += 1

    cauTN = ''
    for v in gt:
        A_list = v[0]

        # Chọn ngẫu nhiên một phần tử thuộc tập A để làm đáp án (vì phần tử không phải là tập con)
        idx_choice = np.random.randint(0, len(A_list))
        pt_thuoc = A_list[idx_choice]

        # Tạo phương án nhiễu 2: Tập một phần tử khác với phần tử đã chọn ở đáp án
        idx_diff = np.random.randint(0, len(A_list))
        while idx_diff == idx_choice:
            idx_diff = np.random.randint(0, len(A_list))
        pt_nhieu = A_list[idx_diff]

        # Tạo phương án nhiễu 3: Tập gồm 2 phần tử đầu tiên của tập A
        tập_nhiều_hai_pt = f"\\left\\{{ {A_list[0]}, {A_list[1]} \\right\\}}"

        # Định dạng chuỗi hiển thị cho tập hợp A theo chuẩn LaTeX
        A_latex = f"\\left\\{{ " + ", ".join(map(str, A_list)) + " \\right\\}}"

        debai = f"""Trong các phương án sau, phương án nào \\textbf{{không}} phải là tập con của tập hợp $A = {A_latex}$?"""

        # BỌC TOÀN BỘ PHƯƠNG ÁN CHỌN TRONG DẤU $ ĐỂ TRÁNH LỖI HIỂN THỊ TEXT TRONG ĐỒNG BỘ MATH_TYPE
        dapso = f"""${pt_thuoc}$"""
        dsnhieu = [
            f"""$\\varnothing$""",
            f"""$\\left\\{{ {pt_nhieu} \\right\\}}$""",
            f"""${tập_nhiều_hai_pt}$"""
        ]

        giai = f"""Ký hiệu tập hợp con phải được đặt trong dấu ngoặc nhọn hoặc ký hiệu tập rỗng $\\varnothing$.\\\\
        Vì ${pt_thuoc}$ là một phần tử thuộc tập hợp $A$, nên ta chỉ có quan hệ thuộc: ${pt_thuoc} \\in A$.\\\\
        Do đó, phương án ${pt_thuoc}$ \\textbf{{không}} phải là tập con của tập hợp $A$."""

        cauTN += MC_SA_answer_text(debai, dapso, dsnhieu, giai, 0, 0, dang)

    return cauTN

def K10_C1_B2_TapConChu_MC_NB(socau, dang):
    x = Symbol('x')
    y = Symbol('y')

    # Bảng chữ cái tiếng Anh dùng để sinh tập hợp ngẫu nhiên
    bang_chu_cai = ['a', 'b', 'c', 'd', 'e', 'm', 'n', 'p', 'q', 'x', 'y', 'z', 'u', 'v', 't']

    gt = []
    dem = len(gt)
    while dem < socau:
        # Sinh ngẫu nhiên số lượng phần tử của tập hợp (2 hoặc 3 phần tử)
        k = np.random.randint(2, 4)

        # Chọn ngẫu nhiên k chữ cái không trùng nhau từ bảng chữ cái
        A_list = list(np.random.choice(bang_chu_cai, size=k, replace=False))
        A_list.sort()  # Sắp xếp để hiển thị theo thứ tự bảng chữ cái cho đẹp

        v = [A_list]
        if v not in gt:
            gt.append(v)
            dem += 1

    cauTN = ''
    for v in gt:
        A_list = v[0]

        # Chọn ngẫu nhiên 1 phần tử nằm trong tập A để làm bẫy cho đáp án đúng
        # Vì phần tử đơn lẻ x thuộc A ký hiệu là x \in A, chứ không phải tập con (phải bọc trong dấu nhọn)
        idx_choice = np.random.randint(0, len(A_list))
        pt_thuoc = A_list[idx_choice]

        # Chọn ngẫu nhiên 1 phần tử khác trong tập A để làm nhiễu tập con đơn tử
        idx_diff = np.random.randint(0, len(A_list))
        while idx_diff == idx_choice and len(A_list) > 1:
            idx_diff = np.random.randint(0, len(A_list))
        pt_nhieu = A_list[idx_diff]

        # Tạo chuỗi hiển thị danh sách các phần tử cho tập A, ngăn cách bởi dấu chấm phẩy ;
        A_elements_str = "; ".join(A_list)
        A_latex = f"\\left\\{{ {A_elements_str} \\right\\}}"

        debai = f"""Trong các phương án sau, phương án nào \\textbf{{không}} phải là tập con của tập hợp $A = {A_latex}$?"""

        # CHỦ ĐỘNG BỌC ĐỒNG BỘ CẶP DẤU DOLLAR DUY NHẤT CHO CÁC PHƯƠNG ÁN CHỌN ĐỂ TRÁNH LỖI TEXT
        dapso = f"""${pt_thuoc}$"""

        # Các phương án nhiễu đều là tập con hợp pháp (Tập rỗng, tập chứa chính nó, tập chứa 1 phần tử)
        dsnhieu = [
            f"""$\\varnothing$""",
            f"""$\\left\\{{ {A_elements_str} \\right\\}}$""",
            f"""$\\left\\{{ {pt_nhieu} \\right\\}}$"""
        ]

        giai = f"""Mỗi phần tử ${pt_thuoc}$ thuộc tập hợp $A$ thì được biểu diễn bởi quan hệ thuộc: ${pt_thuoc} \\in A$.\\\\
        Để biểu diễn một tập hợp con, ta phải sử dụng ký hiệu tập hợp bọc trong dấu ngoặc nhọn, ví dụ $\\left\\{{ {pt_thuoc} \\right\\}} \\subset A$ hoặc tập rỗng $\\varnothing \\subset A$.\\\\
        Do đó, phương án ${pt_thuoc}$ \\textbf{{không}} phải là tập con của tập hợp $A$."""

        cauTN += MC_SA_answer_text(debai, dapso, dsnhieu, giai, 0, 0, dang)

    return cauTN


def K10_C1_B2_TapConKhoang_MC_NB(socau, dang):
    x = Symbol('x')
    y = Symbol('y')

    gt = []
    dem = len(gt)
    while dem < socau:
        # Sinh tập gốc A = [a_val; b_val) với độ dài khoảng đủ lớn để chứa các tập con
        a_val = np.random.randint(-9, 5)
        b_val = np.random.randint(a_val + 5, a_val + 15)  # Đảm bảo b_val luôn lớn hơn a_val ít nhất 5 đơn vị

        # Sinh đáp án đúng (a0; b0) nằm hoàn toàn bên trong [a_val; b_val)
        a0 = np.random.randint(a_val + 1, b_val - 2)
        b0 = np.random.randint(a0 + 1, b_val)

        # Sinh nhiễu 1: [a1; b1) vi phạm ở đầu mút trái (a1 < a_val)
        a1 = np.random.randint(a_val - 5, a_val)
        b1 = np.random.randint(a_val + 1, b_val)  # Bảo đảm b1 > a_val > a1 để tập không bị rỗng

        # Sinh nhiễu 2: (-\infty; b2) chắc chắn vươn về âm vô cùng nên không thể là tập con của A
        b2 = np.random.randint(a_val + 1, b_val)

        # Sinh nhiễu 3: (a3; b_val] vi phạm ở đầu mút phải vì chứa phần tử b_val, trong khi A không chứa b_val
        a3 = np.random.randint(a_val + 1, b_val)

        v = [a_val, b_val, a0, b0, a1, b1, b2, a3]
        if v not in gt:
            gt.append(v)
            dem += 1

    cauTN = ''
    for v in gt:
        a_val, b_val, a0, b0, a1, b1, b2, a3 = v[0], v[1], v[2], v[3], v[4], v[5], v[6], v[7]

        debai = f"""Cho tập hợp $A = [{a_val}; {b_val})$. Trong các tập hợp sau, tập hợp nào là tập con của tập hợp $A$?"""

        # ĐỒNG BỘ BỌC TOÀN BỘ PHƯƠNG ÁN CHỌN TRONG CẶP DẤU $ DUY NHẤT
        dapso = f"""$({a0}; {b0})$"""
        dsnhieu = [
            f"""$[{a1}; {b1})$""",
            f"""$(-\\infty; {b2})$""",
            f"""$({a3}; {b_val}]$"""
        ]

        giai = f"""Điều kiện để một tập số $X$ là tập con của $A = [{a_val}; {b_val})$ là mọi phần tử của $X$ phải thuộc $A$.\\\\
        - Xét phương án $({a0}; {b0})$: Do ${a_val} < {a0} < {b0} < {b_val}$, nên toàn bộ khoảng $({a0}; {b0})$ đều nằm trọn bên trong nửa khoảng $[{a_val}; {b_val})$. Do đó $({a0}; {b0}) \\subset A$.\\\\
        - Các phương án còn lại đều chứa các phần tử không thuộc $A$ (ví dụ: $[{a1}; {b1})$ chứa phần tử nhỏ hơn ${a_val}$, $(-\\infty; {b2})$ chứa các số âm vô cùng, $({a3}; {b_val}]$ chứa phần tử ${b_val}$ mà $A$ không có)."""

        cauTN += MC_SA_answer_text(debai, dapso, dsnhieu, giai, 0, 0, dang)

    return cauTN



def K10_C1_B2_QuanHeThuocTapCon_MC_NB(socau, dang):
    x_sym = Symbol('x')
    y_sym = Symbol('y')

    # Danh sách các chữ cái hoa đặt tên cho tập hợp và chữ thường đặt tên cho phần tử
    chu_hoa = ['A', 'B', 'C', 'D', 'E', 'F', 'G', 'H', 'K', 'M', 'N', 'P', 'Q', 'S', 'T', 'V', 'X', 'Y', 'Z']
    chu_thuong = ['a', 'b', 'c', 'd', 'e', 'g', 'h', 'k', 'm', 'n', 'p', 'q', 't', 'u', 'v', 'x', 'y', 'z']

    gt = []
    dem = len(gt)
    while dem < socau:
        # Lấy ngẫu nhiên 2 chữ cái viết hoa khác nhau làm tên tập hợp
        taps = np.random.choice(chu_hoa, size=2, replace=False)
        Tap_Con = taps[0]
        Tap_Me = taps[1]

        # Lấy ngẫu nhiên 1 chữ cái viết thường làm tên phần tử
        Phan_Tu = np.random.choice(chu_thuong)

        v = [Tap_Con, Tap_Me, Phan_Tu]
        if v not in gt:
            gt.append(v)
            dem += 1

    cauTN = ''
    for v in gt:
        Tap_Con, Tap_Me, Phan_Tu = v[0], v[1], v[2]

        debai = f"""Cho hai tập hợp ${Tap_Con}$, ${Tap_Me}$ thỏa mãn ${Tap_Con} \\subset {Tap_Me}$ và một phần tử ${Phan_Tu} \\in {Tap_Con}$. Tìm khẳng định đúng trong các khẳng định sau."""

        dapso = f"""${Phan_Tu} \\in {Tap_Me}$"""
        dsnhieu = [
            f"""${Phan_Tu} \\subset {Tap_Me}$""",
            f"""${Phan_Tu} \\notin {Tap_Me}$""",
            f"""$\\left\\{{ {Phan_Tu} \\right\\}} \\in {Tap_Con}$"""
        ]

        giai = f"""Vì phần tử ${Phan_Tu}$ thuộc tập hợp ${Tap_Con}$ (ký hiệu ${Phan_Tu} \\in {Tap_Con}$) và mọi phần tử của tập hợp ${Tap_Con}$ đều phải thuộc tập hợp ${Tap_Me}$ (do quan hệ tập con ${Tap_Con} \\subset {Tap_Me}$), nên chắc chắn phần tử ${Phan_Tu}$ phải thuộc tập hợp ${Tap_Me}$. Ký hiệu toán học đúng là ${Phan_Tu} \\in {Tap_Me}$.\\\\
        - Phương án ${Phan_Tu} \\subset {Tap_Me}$ sai vì giữa phần tử và tập hợp chỉ có quan hệ thuộc ($\\in$), không dùng ký hiệu chứa ($\\subset$).\\\\
        - Phương án $\\left\\{{ {Phan_Tu} \\right\\}} \\in {Tap_Con}$ sai vì tập hợp chứa phần tử ${Phan_Tu}$ thì phải dùng quan hệ chứa $\\left\\{{ {Phan_Tu} \\right\\}} \\subset {Tap_Con}$ chứ không phải thuộc."""

        cauTN += MC_SA_answer_text(debai, dapso, dsnhieu, giai, 0, 0, dang)

    return cauTN


def K10_C1_B2_PhepToanTapHopSo_MC_TH(socau, dang):
    x_sym = Symbol('x')
    y_sym = Symbol('y')

    gt = []
    dem = len(gt)
    while dem < socau:
        # Mở rộng dải số nguyên từ -15 đến 15 nhằm hạn chế tối đa việc lặp vô hạn khi socau lớn
        nums = list(np.random.choice(range(-15, 16), size=4, replace=False))
        nums.sort()

        # Tạo cấu trúc đan xen cố định để luôn đảm bảo tập hợp A và B có giao nhau khác rỗng:
        # A = (nums[0]; nums[2]), B = [nums[1]; nums[3]]
        # Với nums đã được sắp xếp, ta luôn có: nums[0] < nums[1] < nums[2] < nums[3]
        a1, a2, b1, b2 = nums[0], nums[1], nums[2], nums[3]

        # Chọn ngẫu nhiên phép toán: 0: Giao (\cap), 1: Hợp (\cup), 2: Hiệu A \setminus B, 3: Hiệu B \setminus A
        phep_toan = np.random.randint(0, 4)

        v = [a1, a2, b1, b2, phep_toan]
        if v not in gt:
            gt.append(v)
            dem += 1

    cauTN = ''
    for v in gt:
        a1, a2, b1, b2 = v[0], v[1], v[2], v[3]
        phep_toan = v[4]

        # Định dạng hiển thị chuỗi tập hợp số thực theo chuẩn Việt Nam (dấu ngăn cách chấm phẩy `;`)
        A_str = f"({a1}; {b1})"
        B_str = f"[{a2}; {b2}]"

        # Xác định chính xác kết quả của từng phép toán theo lý thuyết tập hợp số thực
        giao_taps = f"[{a2}; {b1})"
        hop_taps = f"({a1}; {b2}]"
        hieu_A_B = f"({a1}; {a2})"
        hieu_B_A = f"[{b1}; {b2}]"

        if phep_toan == 0:
            debai = f"""Cho hai tập hợp $A = {A_str}$, $B = {B_str}$. Tìm tập hợp $A \\cap B$."""
            dapso = f"""${giao_taps}$"""
            dsnhieu = [f"""${hop_taps}$""", f"""${hieu_A_B}$""", f"""${hieu_B_A}$"""]
            giai = f"""Theo định nghĩa, phép toán giao của hai tập hợp $A \\cap B$ chứa các phần tử vừa thuộc $A$ vừa thuộc $B$.\\\\
