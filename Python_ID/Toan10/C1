def L10_C1_B2_020_MC_02(socau, dang):
    x_sym = Symbol('x')
    y_sym = Symbol('y')

    gt = []
    dem = len(gt)
    while dem < socau:
        lop = int(np.random.choice([35, 40, 42, 45, 50]))
