            m = np.random.randint(-9, 9)
        n = np.random.randint(-9, 9)

        fx = x ** 2 - m * x + n
        gx = m * x - n
        ham = np.random.choice([fx, gx])

        dk1 = random.choice(['\\exists', '\\forall'])
        dk2 = random.choice(['>', '<', '\\le', '\\ge', '=', '\\ne'])

        KiHieu = ['\\exists', '\\forall', '>', '<', '\\le', '\\ge', '=', '\\ne']
        PhuDinh = ['\\forall', '\\exists', '\\le', '\\ge', '>', '<', '\\ne', '=']
        PhuDinhList = list(zip(KiHieu, PhuDinh))
        PhuDinhDict = dict(PhuDinhList)

        if dk2 == '>':
            PhuDinhSai = '<'
        elif dk2 == '<':
            PhuDinhSai = '>'
        elif dk2 == '\\le':
            PhuDinhSai = '\\ge'
        elif dk2 == '\\ge':
            PhuDinhSai = '\\le'
        else:
            PhuDinhSai = dk2

        # Chống trùng
