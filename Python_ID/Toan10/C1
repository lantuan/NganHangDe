def K10_C1_B1_PhuDinhMenhDeLogic_MC_TH(socau, dang):
    x = Symbol('x')
    y = Symbol('y')

    gt = []
    dem = len(gt)
    while dem < socau:
        k = np.random.randint(0, 10)

        # LOẠI BỎ TOÀN BỘ DẤU TỰ BỌC $ Ở ĐÂY ĐỂ TRÁNH LỖI NHÂN ĐÔI DẤU ĐÔ-LA
        if k == 0:
            P = r"\forall x\in \mathbb{Z}, x^3 > x"
            p = r"\exists x\in \mathbb{Z}, x^3 \le x"
            p1 = r"\forall x\in \mathbb{Z}, x^3 \le x"
            p2 = r"\forall x \not\in \mathbb{Z}, x^3 \le x"
            p3 = r"\exists x \not\in \mathbb{Z}, x^3 \le x"
        elif k == 1:
            P = r"\forall n\in \mathbb{N}, n^2 > n"
            p = r"\exists n\in \mathbb{N}, n^2 \le n"
            p1 = r"\forall n\in \mathbb{N}, n^2 \le n"
            p2 = r"\exists n\not\in \mathbb{N}, n^2 \le n"
            p3 = r"\forall n\not\in \mathbb{N}, n^2 \le n"
        elif k == 2:
            P = r"\exists x\in \mathbb{R}, \dfrac{1}{x} = x"
            p = r"\forall x\in \mathbb{R}, \dfrac{1}{x} \ne x"
            p1 = r"\exists x\in \mathbb{R}, \dfrac{1}{x} \ne x"
            p2 = r"\forall x\in \mathbb{R}, \dfrac{1}{x} = -x"
            p3 = r"\exists x\in \mathbb{R}, \dfrac{1}{x} = -x"
        elif k == 3:
            P = r"\exists n\in \mathbb{N}, \dfrac{1}{n}\in \mathbb{N}"
            p = r"\forall n\in \mathbb{N}, \dfrac{1}{n}\not\in \mathbb{N}"
            p1 = r"\exists n\in \mathbb{N}, \dfrac{1}{n}\not\in \mathbb{N}"
            p2 = r"\forall n\in \mathbb{N}, \dfrac{1}{n} \in \mathbb{Z}"
            p3 = r"\exists n\in \mathbb{N}, \dfrac{1}{n} \in \mathbb{Z}"
        elif k == 4:
            P = r"\forall x\in \mathbb{R}, |x| < 0"
            p = r"\exists x\in \mathbb{R}, |x| \ge 0"
            p1 = r"\forall x\in \mathbb{R}, |x| \ge 0"
            p2 = r"\exists x\in \mathbb{R}, |x| > 0"
            p3 = r"\forall x\in \mathbb{R}, |x| > 0"
        elif k == 5:
            P = r"\exists x\in \mathbb{Z}, x^2 \le 0"
            p = r"\forall x\in \mathbb{Z}, x^2 > 0"
            p1 = r"\exists x\in \mathbb{Z}, x^2 > 0"
            p2 = r"\forall x\in \mathbb{Z}, x^2 \ge 0"
            p3 = r"\exists x\in \mathbb{Z}, x^2 \ge 0"
        elif k == 6:
            P = r"\forall x\in \mathbb{R}, x^2 - x + 7 > 0"
            p = r"\exists x\in \mathbb{R}, x^2 - x + 7 \le 0"
            p1 = r"\forall x\in \mathbb{R}, x^2 - x + 7 \le 0"
            p2 = r"\exists x\in \mathbb{R}, x^2 - x + 7 < 0"
            p3 = r"\forall x\in \mathbb{R}, x^2 - x + 7 < 0"
        elif k == 7:
            P = r"\exists x\in \mathbb{Q}, x^2 = 2"
            p = r"\forall x\in \mathbb{Q}, x^2 \ne 2"
            p1 = r"\exists x\in \mathbb{Q}, x^2 \ne 2"
            p2 = r"\forall x\not\in \mathbb{Q}, x^2 = 2"
            p3 = r"\exists x\not\in \mathbb{Q}, x^2 \ne 2"
        elif k == 8:
            P = r"\forall n\in \mathbb{N}, 2^n \ge n + 2"
            p = r"\exists n\in \mathbb{N}, 2^n < n + 2"
            p1 = r"\forall n\in \mathbb{N}, 2^n < n + 2"
            p2 = r"\exists n\in \mathbb{N}, 2^n \le n + 2"
            p3 = r"\forall n\in \mathbb{N}, 2^n \le n + 2"
        else:
            P = r"\exists x\in \mathbb{R}, x^2 + 1 = 0"
            p = r"\forall x\in \mathbb{R}, x^2 + 1 \ne 0"
            p1 = r"\exists x\in \mathbb{R}, x^2 + 1 \ne 0"
            p2 = r"\forall x\in \mathbb{R}, x^2 + 1 > 0"
            p3 = r"\forall x\in \mathbb{R}, x^2 + 1 < 0"

        v = [P, p, p1, p2, p3]
