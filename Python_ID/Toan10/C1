import numpy as np
from sympy import Symbol


def K10_C1_B2_TimThamSoTapHop_MC_VD(socau, dang):
    x_sym = Symbol('x')
    y_sym = Symbol('y')

    gt = []
    dem = len(gt)
    while dem < socau:
        # Mở rộng dải số nguyên để đa dạng bài toán và tránh lặp vô hạn
        a_val = np.random.randint(-15, 5)
        b_val = np.random.randint(a_val + 5, 16)  # Đảm bảo tập A luôn rộng

        # Sinh n_val nằm hoàn toàn bên trong khoảng của tập A
        n_val = np.random.randint(a_val + 1, b_val)

        # Số lượng giá trị nguyên m thỏa mãn n_val < m <= b_val là (b_val - n_val)
        z_ans = b_val - n_val

        # Chỉ chấp nhận bộ dữ liệu nếu số lượng giá trị nguyên m lớn hơn 0
        if z_ans <= 0:
            continue

        v = [a_val, b_val, n_val, z_ans]
        if v not in gt:
            gt.append(v)
            dem += 1

    cauTN = ''
    for v in gt:
        a_val, b_val, n_val, z_ans = v[0], v[1], v[2], v[3]

        debai = f"""Cho hai tập hợp $A = \\left[ {a_val}; {b_val} \\right]$ và $B = \\left( {n_val}; m \\right]$. Có tất cả bao nhiêu giá trị nguyên của tham số $m$ để $A \\cup B = A$?"""

        dapso = f"""${z_ans}$"""

        # Tự động sinh danh sách nhiễu số nguyên xung quanh đáp án, đảm bảo không trùng và không âm
        ds_nhieu_so = []
        sai_so = [-2, -1, 1, 2, 3, 4]
        for delta in sai_so:
            val_nhieu = z_ans + delta
            if val_nhieu >= 0 and val_nhieu != z_ans and val_nhieu not in ds_nhieu_so:
                ds_nhieu_so.append(val_nhieu)

        # Bốc chính xác 3 giá trị nhiễu phân biệt
        nhieu_chon = list(np.random.choice(ds_nhieu_so, size=3, replace=False))

        dsnhieu = [
            f"""${nhieu_chon[0]}$""",
            f"""${nhieu_chon[1]}$""",
            f"""${nhieu_chon[2]}$"""
        ]

        # ĐÃ SỬA LỖI: Sửa } thành }} ở cuối câu lệnh \text{...} để f-string biên dịch chính xác
        giai = f"""- Để tập hợp $B = \\left( {n_val}; m \\right]$ tồn tại và không rỗng, điều kiện cần là: $m > {n_val}$.\\\\
        - Theo lý thuyết tập hợp, ta có phép toán hợp: $A \\cup B = A \\Leftrightarrow B \\subset A$.\\\\
        - Để tập hợp $B = \\left( {n_val}; m \\right]$ là tập con của đoạn $A = \\left[ {a_val}; {b_val} \\right]$, điểm mút của $B$ phải nằm trọn trong phạm vi của $A$, tức là:\\\\
        $\\begin{{cases}} {n_val} \\ge {a_val} \\text{{ (luôn đúng do cách chọn)}} \\\\ m \\le {b_val} \\end{{cases}}$\\\\
        - Kết hợp hai điều kiện trên, ta tìm được tập giá trị của tham số $m$ là: ${n_val} < m \\le {b_val}$.\\\\
        - Vì $m \\in \\mathbb{{Z}}$, số lượng các giá trị nguyên của $m$ thỏa mãn là: ${b_val} - {n_val} = {z_ans}$ giá trị.\\\\
        Vậy có tất cả ${z_ans}$ giá trị nguyên của tham số $m$ thỏa mãn yêu cầu đề bài."""

        cauTN += MC_SA_answer_text(debai, dapso, dsnhieu, giai, 0, 0, dang)

    return cauTN

