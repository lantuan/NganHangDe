        giai = f"""Phủ định của mệnh đề chứa kí hiệu $\\forall$ là $\\exists$ và ngược lại, đồng thời phủ định mệnh đề tính chất phía sau."""

        # Đã sửa đổi gọi hàm sang MC_SA_answer_const theo đúng yêu cầu bài toán công thức
        cauTN += MC_SA_answer_const(debai, dapso, dsnhieu, giai, 0, 0, dang)

    # Làm sạch chuỗi hiển thị biểu thức LaTeX
