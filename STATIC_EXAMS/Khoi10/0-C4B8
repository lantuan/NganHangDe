	&=\left(\overrightarrow{GA}+\overrightarrow{GB}+\overrightarrow{GC}\right)+\overrightarrow{BC}+\overrightarrow{CD}\\
	&=\overrightarrow{BC}+\overrightarrow{CD}=\overrightarrow{BD}$.
\end{aligned}
$$

