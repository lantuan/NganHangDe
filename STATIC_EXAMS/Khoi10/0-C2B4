	\fill[pattern=north east lines,smooth]
	plot[domain=-3:8] (\x,{0*(\x)+6})
	-- plot[domain=8:-3] (\x,{2*(\x)-2})
	-- cycle;
	
	\fill[pattern=north east lines,smooth]
	plot[domain=-3:8] (\x,{(1/2)*(\x)-1})
